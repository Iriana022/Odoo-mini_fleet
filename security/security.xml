<odoo>
    <data noupdate="1">
        <record id="module_category_mini_fleet" model="ir.module.category">
            <field name="name">Gestion de Flotte</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_fleet_reader" model="res.groups">
            <field name="name">Lecteur</field>
            <field name="category_id" ref="module_category_mini_fleet"/>
        </record>

        <record id="group_fleet_user" model="res.groups">
            <field name="name">Gestionnaire parc</field>
            <field name="category_id" ref="module_category_mini_fleet"/>
            <field name="implied_ids" eval="[(4, ref('group_fleet_reader'))]"/>
        </record>

        <record id="group_fleet_manager" model="res.groups">
            <field name="name">Responsable</field>
            <field name="category_id" ref="module_category_mini_fleet"/>
            <field name="implied_ids" eval="[(4, ref('group_fleet_user'))]"/>
        </record>
    </data>
</odoo>