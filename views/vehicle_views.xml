<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action de la fenêtre -->
    <record id="action_mini_vehicle" model="ir.actions.act_window">
        <field name="name">Véhicules</field>
        <field name="res_model">mini.vehicle</field>
        <field name="view_mode">tree,form,kanban</field>
    </record>

    <!-- Vue Liste (Tree) avec tous les champs -->
    <record id="view_mini_vehicle_tree" model="ir.ui.view">
        <field name="name">mini.vehicle.tree</field>
        <field name="model">mini.vehicle</field>
        <field name="arch" type="xml">
            <tree string="Véhicules">
                <field name="name"/>
                <field name="brand"/>
                <field name="model"/>
                <field name="year"/>
                <field name="color"/>
                <field name="mileage"/>
                <field name="chassis_no"/>
                <field name="driver_id"/>
                <field name="driver_phone" widget="phone"/>
                <field name="state" widget="badge" decoration-success="state == 'running'" decoration-info="state == 'draft'" decoration-warning="state == 'maintenance'"/>
            </tree>
        </field>
    </record>

    <!-- Vue Kanban -->
    <record id="view_mini_vehicle_kanban" model="ir.ui.view">
        <field name="name">mini.vehicle.kanban</field>
        <field name="model">mini.vehicle</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile">
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted">
                                    <field name="brand"/> - <field name="model"/>
                                </div>
                                <div t-if="record.driver_id.raw_value">
                                    Conducteur : <field name="driver_id"/>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_right">
                                        <field name="state" widget="badge" decoration-success="state == 'running'" decoration-info="state == 'draft'" decoration-warning="state == 'maintenance'"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vue Formulaire (Form) -->
    <record id="view_mini_vehicle_form" model="ir.ui.view">
        <field name="name">mini.vehicle.form</field>
        <field name="model">mini.vehicle</field>
        <field name="arch" type="xml">
            <form string="Véhicule">
                <header>
                    <button name="action_set_stock" type="object" string="Réceptionner (En stock)" attrs="{'invisible': [('state', 'not in', ['draft'])]}" class="oe_highlight"/>
                    <button name="action_set_running" type="object" string="Mettre en fonction" attrs="{'invisible': [('state', 'not in', ['stock'])]}" class="oe_highlight"/>
                    <button name="action_set_rental" type="object" string="Mettre en location" attrs="{'invisible': [('state', 'not in', ['stock'])]}"/>
                    <button name="action_set_stock" type="object" string="Retour en stock" attrs="{'invisible': [('state', 'not in', ['running', 'rental'])]}"/>
                    <button name="action_set_sold" type="object" string="Vendre" attrs="{'invisible': [('state', 'not in', ['running', 'rental'])]}" class="btn-danger" confirm="Êtes-vous sûr de vouloir marquer ce véhicule comme vendu ?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,stock,running,rental,sold"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Immatriculation..."/>
                        </h1>
                    </div>
                    <notebook>
                        <page string="Infos véhicule">
                            <group>
                                <group string="Informations Générales">
                                    <field name="brand"/>
                                    <field name="model"/>
                                    <field name="year"/>
                                    <field name="color"/>
                                </group>
                                <group string="Technique">
                                    <field name="chassis_no"/>
                                    <field name="mileage"/>
                                </group>
                            </group>
                        </page>
                        <page string="Conducteur">
                            <group>
                                <field name="driver_id"/>
                                <field name="driver_name"/>
                                <field name="driver_phone" widget="phone"/>
                            </group>
                        </page>
                        <page string="Historique">
                            <field name="log_ids">
                                <tree editable="bottom">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>